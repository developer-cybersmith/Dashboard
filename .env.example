# ── Environment variable template ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — this .env.example is the only file committed to git.

# MongoDB Atlas connection string (required on Railway for persistent storage)
# Leave blank locally to fall back to data/db.json
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Currency exchange rate API key — https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key_here

# Shared login password for all authorized users
DEFAULT_PASSWORD=Mitkat@2026

# Server port (Railway sets this automatically — only needed for local dev)
PORT=4000
