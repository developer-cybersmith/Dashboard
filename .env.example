# MongoDB connection string (required on Railway for persistent storage)
# Leave unset locally to use data/db.json instead
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Shared login password for all 4 authorized users (set this on Railway too)
DEFAULT_PASSWORD=Mitkat@2026

# Railway sets PORT automatically — do not hardcode in production
# PORT=4000
