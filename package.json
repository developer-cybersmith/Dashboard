{
  "name": "mitkat-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n API,WEB -c magenta,cyan \"npm:server\" \"npm:dev:web\"",
